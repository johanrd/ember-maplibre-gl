{
  "name": "ember-maplibre-gl",
  "version": "0.4.0",
  "packageManager": "pnpm@10.32.1",
  "description": "Declarative MapLibre GL JS components for Ember.js",
  "keywords": [
    "ember-addon",
    "maplibre",
    "maplibre-gl",
    "maps",
    "glimmer",
    "ember"
  ],
  "repository": "https://github.com/johanrd/ember-maplibre-gl",
  "license": "MIT",
  "author": "",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./addon-main.js": "./addon-main.cjs",
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup --config",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:publish": "pnpm build && publint run --level error",
    "lint:types": "ember-tsc --noEmit",
    "prepack": "rollup --config",
    "start": "vite dev",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.8.9",
    "decorator-transforms": "^2.2.2",
    "ember-modifier": "^4.2.0",
    "ember-resources": "^7.0.0"
  },
  "peerDependencies": {
    "@glimmer/component": ">= 1.1.2 || >= 2.0.0",
    "ember-source": ">= 3.28.0",
    "maplibre-gl": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@glimmer/component": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@babel/plugin-transform-typescript": "^7.25.2",
    "@babel/runtime": "^7.25.6",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/library-tsconfig": "^2.0.0",
    "@ember/test-helpers": "^5.2.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.20.1",
    "@embroider/vite": "^1.1.5",
    "@eslint/js": "^9.17.0",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.0.3",
    "@glint/template": "^1.6.1",
    "@glint/tsserver-plugin": "^2.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^1.12.0",
    "@types/qunit": "^2.19.12",
    "@types/sinon": "^21.0.0",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.2",
    "ember-source": "^6.11.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-template-lint": "^7.9.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-ember": "^12.3.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.1",
    "globals": "^17.4.0",
    "mapbox-gl": "^1.13.3",
    "maplibre-gl": "^5.21.0",
    "prettier": "^3.4.2",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "publint": "^0.3.16",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.4.0",
    "release-plan": "^0.17.4",
    "rollup": "^4.22.5",
    "sinon": "^21.0.3",
    "testem": "^3.15.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^8.0.1"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs",
    "app-js": {
      "./components/maplibre-gl-call.js": "./dist/_app_/components/maplibre-gl-call.js",
      "./components/maplibre-gl-control.js": "./dist/_app_/components/maplibre-gl-control.js",
      "./components/maplibre-gl-image.js": "./dist/_app_/components/maplibre-gl-image.js",
      "./components/maplibre-gl-layer.js": "./dist/_app_/components/maplibre-gl-layer.js",
      "./components/maplibre-gl-marker.js": "./dist/_app_/components/maplibre-gl-marker.js",
      "./components/maplibre-gl-on.js": "./dist/_app_/components/maplibre-gl-on.js",
      "./components/maplibre-gl-popup.js": "./dist/_app_/components/maplibre-gl-popup.js",
      "./components/maplibre-gl-source.js": "./dist/_app_/components/maplibre-gl-source.js",
      "./components/maplibre-gl.js": "./dist/_app_/components/maplibre-gl.js"
    }
  }
}
